# Database (Neon DB - get from https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/shiftsync?sslmode=require"

# Redis (Redis Cloud - get from https://redis.com/try-free)
REDIS_URL="redis://default:password@redis-xxxxx.cloud.redislabs.com:12345"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="24h"

# API
API_PORT=3001
API_URL="http://localhost:3001"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Node Environment
NODE_ENV="development"

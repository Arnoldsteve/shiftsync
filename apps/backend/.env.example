# Node Environment
NODE_ENV=development

# API Configuration
API_PORT=3001

# Database (Neon DB)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/shiftsync?sslmode=require"

# Redis (Redis Cloud)
REDIS_URL="redis://default:password@redis-xxxxx.cloud.redislabs.com:12345"

# JWT Authentication
JWT_SECRET="your-secret-key-at-least-32-characters-long-change-in-production"
JWT_EXPIRES_IN="24h"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

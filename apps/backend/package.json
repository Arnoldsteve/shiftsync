{
  "name": "@shiftsync/backend",
  "version": "1.0.0",
  "description": "ShiftSync NestJS Backend API",
  "scripts": {
    "build": "nest build",
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/main.ts",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:integration": "vitest run test/integration",
    "test:integration:watch": "vitest test/integration",
    "test:unit": "vitest run src",
    "test:unit:watch": "vitest src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^5.20.5",
    "@bull-board/express": "^5.20.5",
    "@bull-board/nestjs": "^5.20.5",
    "@casl/ability": "^6.8.0",
    "@casl/prisma": "^1.6.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.3.8",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/websockets": "^10.3.8",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/config": "^7.6.0",
    "@scalar/nestjs-api-reference": "^1.1.5",
    "@shiftsync/shared": "workspace:*",
    "argon2": "^0.40.1",
    "bullmq": "^5.7.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^17.3.1",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.0.0",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^1.5.0",
    "fast-check": "^3.17.1",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
